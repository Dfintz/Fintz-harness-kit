{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./harness.config.schema.json",
  "title": "Harness Config",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "provider": { "type": "string" },
          "model": { "type": "string" },
          "useFor": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "graph": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": {
          "type": "string",
          "enum": ["understand-anything", "graphify", "both"]
        },
        "pluginRoot": { "type": "string" },
        "path": { "type": "string" },
        "graphHtmlPath": { "type": "string" },
        "sync": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "rebuildVectorIndex": { "type": "boolean" },
            "rebuildMemoryLinkIndex": { "type": "boolean" },
            "continueOnSyncError": { "type": "boolean" }
          }
        },
        "observability": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "eventsPath": { "type": "string" }
          }
        },
        "graphify": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "path": { "type": "string" },
            "graphHtmlPath": { "type": "string" },
            "refreshCommand": { "type": "string" },
            "refreshCwd": { "type": "string" }
          }
        }
      }
    },
    "llm": {
      "type": "object",
      "additionalProperties": true
    },
    "experiments": {
      "type": "object",
      "additionalProperties": true
    },
    "evolve": {
      "type": "object",
      "additionalProperties": true
    },
    "traceGrading": {
      "type": "object",
      "additionalProperties": true
    },
    "otel": {
      "type": "object",
      "additionalProperties": true
    },
    "dashboard": {
      "type": "object",
      "additionalProperties": true
    },
    "routing": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "defaultMode": { "type": "string" },
        "requireDistinctReviewerAndImplementer": { "type": "boolean" },
        "trivialStartsAt": { "type": "string" },
        "nonTrivialStages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "trivialKeywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nonTrivialKeywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "profiles": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "description": { "type": "string" },
              "mode": { "type": "string" },
              "stages": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "required": ["project", "commands"]
}
