{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./harness.config.schema.json",
  "title": "Harness Config",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "provider": { "type": "string" },
          "model": { "type": "string" },
          "useFor": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "graph": {
      "type": "object",
      "additionalProperties": true
    },
    "llm": {
      "type": "object",
      "additionalProperties": true
    },
    "experiments": {
      "type": "object",
      "additionalProperties": true
    },
    "evolve": {
      "type": "object",
      "additionalProperties": true
    },
    "traceGrading": {
      "type": "object",
      "additionalProperties": true
    },
    "otel": {
      "type": "object",
      "additionalProperties": true
    },
    "dashboard": {
      "type": "object",
      "additionalProperties": true
    },
    "routing": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "defaultMode": { "type": "string" },
        "requireDistinctReviewerAndImplementer": { "type": "boolean" },
        "trivialStartsAt": { "type": "string" },
        "stageModels": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Optional per-stage model ids overlaying the implementer/reviewer/arbiter role defaults. The router validates the resolved models for per-stage independence."
        },
        "nonTrivialStages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "trivialKeywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nonTrivialKeywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "profiles": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "description": { "type": "string" },
              "mode": { "type": "string" },
              "stages": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "required": ["project", "commands"]
}
