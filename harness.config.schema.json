{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./harness.config.schema.json",
  "title": "Harness Config",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "provider": { "type": "string" },
          "model": { "type": "string" },
          "useFor": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "graph": {
      "type": "object",
      "additionalProperties": true
    },
    "llm": {
      "type": "object",
      "additionalProperties": true
    },
    "experiments": {
      "type": "object",
      "additionalProperties": true
    },
    "evolve": {
      "type": "object",
      "additionalProperties": true
    },
    "traceGrading": {
      "type": "object",
      "additionalProperties": true
    },
    "otel": {
      "type": "object",
      "additionalProperties": true
    },
    "dashboard": {
      "type": "object",
      "additionalProperties": true
    },
    "routing": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "defaultMode": { "type": "string" },
        "requireDistinctReviewerAndImplementer": { "type": "boolean" },
        "trivialStartsAt": { "type": "string" },
        "stageModels": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": true,
                "required": ["model"],
                "properties": {
                  "model": { "type": "string" },
                  "fallbacks": {
                    "type": "array",
                    "description": "Ordered degradation candidates (model id string or { model } object). The runtime uses the first available candidate and logs which one won.",
                    "items": {
                      "oneOf": [
                        { "type": "string" },
                        {
                          "type": "object",
                          "required": ["model"],
                          "additionalProperties": true,
                          "properties": { "model": { "type": "string" } }
                        }
                      ]
                    }
                  }
                }
              }
            ]
          },
          "description": "Optional per-stage model assignment overlaying the implementer/reviewer/arbiter role defaults. A value is a bare model id string or an object { model, fallbacks }. The router validates the resolved models for per-stage independence and keeps the security/QA gate's candidate list (primary + fallbacks) disjoint from the implementer's."
        },
        "defaultTaskClass": { "type": "string" },
        "stageModelSets": {
          "type": "object",
          "description": "Named per-stage model maps (e.g. exploratory vs deterministic) selected by taskClassMatrix / profiles. Same value shape as stageModels.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["model"],
                  "additionalProperties": true,
                  "properties": {
                    "model": { "type": "string" },
                    "fallbacks": { "type": "array", "items": { "type": "string" } }
                  }
                }
              ]
            }
          }
        },
        "taskClassMatrix": {
          "type": "array",
          "description": "Ordered keyword rules; the first match selects a profile / model set / mode (falling back to defaultTaskClass when nothing matches).",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "reason": { "type": "string" },
              "profile": { "type": "string" },
              "mode": { "type": "string" },
              "modelSet": { "type": "string" },
              "stages": { "type": "array", "items": { "type": "string" } },
              "matchAnyKeywords": { "type": "array", "items": { "type": "string" } },
              "matchAllKeywords": { "type": "array", "items": { "type": "string" } },
              "matchNoneKeywords": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "nonTrivialStages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "trivialKeywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nonTrivialKeywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "profiles": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "description": { "type": "string" },
              "mode": { "type": "string" },
              "stages": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "required": ["project", "commands"]
}
