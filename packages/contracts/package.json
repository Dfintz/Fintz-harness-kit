{
  "name": "@sc-fleet-manager/contracts",
  "version": "1.0.0",
  "private": true,
  "description": "Contract testing infrastructure for SC Fleet Manager",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "test:pact": "jest --testMatch='**/*.pact.test.ts'",
    "pact:publish": "pact-broker publish pacts --consumer-app-version=$(git rev-parse HEAD) --broker-base-url=${PACT_BROKER_URL}"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "eslint": "^9.39.4",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "@typescript/native": "npm:typescript@^7.0.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "peerDependencies": {
    "@sc-fleet-manager/shared-types": "^1.0.0"
  }
}
