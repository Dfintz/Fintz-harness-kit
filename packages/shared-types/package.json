{
  "name": "@sc-fleet-manager/shared-types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for Star Citizen Fleet Manager",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "generate:openapi": "echo 'OpenAPI type generation is configured in the backend package. Run npm run openapi:generate in the backend directory.'"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./intel": {
      "types": "./dist/intel/index.d.ts",
      "import": "./dist/intel/index.js"
    },
    "./faq": {
      "types": "./dist/faq/index.d.ts",
      "import": "./dist/faq/index.js"
    },
    "./changelog": {
      "types": "./dist/changelog/index.d.ts",
      "import": "./dist/changelog/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "star-citizen",
    "fleet-manager",
    "types"
  ]
}
