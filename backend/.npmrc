# NPM Configuration for Security
# Place this file in backend directory as .npmrc

# Security audit settings
audit-level=moderate
audit=true

# Package installation settings
save-exact=false
save-prefix=^
engine-strict=true

# Package integrity settings
package-lock=true

# Logging
loglevel=warn

# Network settings
strict-ssl=true

# Update settings
update-notifier=true

# Script execution
ignore-scripts=false

# Registry
registry=https://registry.npmjs.org/
