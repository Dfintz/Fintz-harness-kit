import { Repository, FindOptionsWhere, In, Between, LessThanOrEqual, MoreThanOrEqual } from 'typeorm';
import { AppDataSource } from '../../config/database';
import { Activity, ActivityType, ActivityStatus, ActivityVisibility } from '../../models/Activity';
import { TenantService } from '../base/TenantService';
import logger from '../../utils/logger';

export interface CreateActivityDTO {
    title: string;
    description: string;
    activityType: ActivityType;
    creatorId: string;
    creatorName: string;
    organizationId?: string;
    organizationName?: string;
    visibility?: ActivityVisibility;
    scheduledStartDate?: Date;
    scheduledEndDate?: Date;
    estimatedDuration?: number;
    location?: string;
    systemLocation?: string;
    maxParticipants?: number;
    minParticipants?: number;
    roleRequirements?: any[];
    resourceRequirements?: any[];
    rewardCredits?: number;
    rewardReputation?: number;
    tags?: string[];
    categories?: string[];
    metadata?: any;
}

export interface ActivitySearchParams {
    activityType?: ActivityType;
    status?: ActivityStatus;
    visibility?: ActivityVisibility;
    location?: string;
    systemLocation?: string;
    tags?: string[];
    categories?: string[];
    startDate?: Date;
    endDate?: Date;
    organizationId?: string;
    creatorId?: string;
    limit?: number;
    offset?: number;
    sortBy?: string;
    sortOrder?: 'ASC' | 'DESC';
}

export interface ActivityStatistics {
    total: number;
    byType: Record<ActivityType, number>;
    byStatus: Record<ActivityStatus, number>;
    totalParticipants: number;
    averageParticipants: number;
    completionRate: number;
    upcomingCount: number;
    overdueCount: number;
}

/**
 * ActivityService - Core Operations
 * 
 * Handles basic CRUD operations for activities
 * Phase 4.1 - Domain Separation
 * 
 * Responsibilities:
 * - Activity creation and updates
 * - Activity search and retrieval
 * - Basic activity management
 * - Activity statistics
 * 
 * @author GitHub Copilot
 * @since October 2025
 */
export class ActivityService extends TenantService<Activity> {
    
    constructor() {
        super(AppDataSource.getRepository(Activity));
    }

    // ==================== CREATE ACTIVITY ====================

    /**
     * Create a new activity (tenant-scoped)
     * @param organizationId - Organization creating the activity
     * @param dto - Activity data
     */
    async createActivity(organizationId: string, dto: CreateActivityDTO): Promise<Activity> {
        // Use the base class create method which automatically sets organizationId
        const activity = await this.create(organizationId, {
            title: dto.title,
            description: dto.description,
            activityType: dto.activityType,
            status: ActivityStatus.DRAFT,
            visibility: dto.visibility || ActivityVisibility.ORGANIZATION,
            creatorId: dto.creatorId,
            creatorName: dto.creatorName,
            organizationName: dto.organizationName,
            scheduledStartDate: dto.scheduledStartDate,
            scheduledEndDate: dto.scheduledEndDate,
            estimatedDuration: dto.estimatedDuration,
            location: dto.location,
            systemLocation: dto.systemLocation,
            maxParticipants: dto.maxParticipants,
            minParticipants: dto.minParticipants || 1,
            currentParticipants: 1,
            roleRequirements: dto.roleRequirements,
            resourceRequirements: dto.resourceRequirements,
            rewardCredits: dto.rewardCredits || 0,
            rewardReputation: dto.rewardReputation || 0,
            tags: dto.tags || [],
            categories: dto.categories || [],
            metadata: dto.metadata,
            participants: [{
                userId: dto.creatorId,
                userName: dto.creatorName,
                organizationId,
                organizationName: dto.organizationName,
                role: 'leader',
                status: 'accepted',
                joinedAt: new Date()
            }],
            participatingOrgs: [{
                organizationId,
                organizationName: dto.organizationName!,
                role: 'host',
                status: 'accepted',
                joinedAt: new Date()
            }]
        });

        logger.info(`Activity created: ${activity.id} by ${dto.creatorId} in org ${organizationId}`);
        return activity;
    }

    // ==================== READ OPERATIONS ====================

    /**
     * Get activity by ID (tenant-scoped)
     */
    async getActivityById(id: string): Promise<Activity | null> {
        return await this.findById(id);
    }

    /**
     * Search activities with filters (tenant-scoped)
     */
    async searchActivities(
        organizationId: string,
        params: ActivitySearchParams
    ): Promise<{ activities: Activity[]; total: number }> {
        const queryBuilder = this.repository.createQueryBuilder('activity')
            .where('activity.organizationId = :organizationId', { organizationId });

        // Apply filters
        if (params.activityType) {
            queryBuilder.andWhere('activity.activityType = :activityType', { 
                activityType: params.activityType 
            });
        }

        if (params.status) {
            queryBuilder.andWhere('activity.status = :status', { status: params.status });
        }

        if (params.visibility) {
            queryBuilder.andWhere('activity.visibility = :visibility', { 
                visibility: params.visibility 
            });
        }

        if (params.location) {
            queryBuilder.andWhere('activity.location ILIKE :location', { 
                location: `%${params.location}%` 
            });
        }

        if (params.systemLocation) {
            queryBuilder.andWhere('activity.systemLocation ILIKE :systemLocation', { 
                systemLocation: `%${params.systemLocation}%` 
            });
        }

        if (params.tags && params.tags.length > 0) {
            queryBuilder.andWhere('activity.tags && :tags', { tags: params.tags });
        }

        if (params.categories && params.categories.length > 0) {
            queryBuilder.andWhere('activity.categories && :categories', { 
                categories: params.categories 
            });
        }

        if (params.startDate) {
            queryBuilder.andWhere('activity.scheduledStartDate >= :startDate', { 
                startDate: params.startDate 
            });
        }

        if (params.endDate) {
            queryBuilder.andWhere('activity.scheduledEndDate <= :endDate', { 
                endDate: params.endDate 
            });
        }

        if (params.creatorId) {
            queryBuilder.andWhere('activity.creatorId = :creatorId', { 
                creatorId: params.creatorId 
            });
        }

        // Get total count
        const total = await queryBuilder.getCount();

        // Apply sorting
        const sortBy = params.sortBy || 'scheduledStartDate';
        const sortOrder = params.sortOrder || 'ASC';
        queryBuilder.orderBy(`activity.${sortBy}`, sortOrder);

        // Apply pagination
        if (params.limit) {
            queryBuilder.limit(params.limit);
        }
        if (params.offset) {
            queryBuilder.offset(params.offset);
        }

        const activities = await queryBuilder.getMany();

        return { activities, total };
    }

    /**
     * Get activities for a specific user (tenant-scoped)
     */
    async getActivitiesForUser(
        organizationId: string,
        userId: string,
        filters?: {
            status?: ActivityStatus[];
            activityType?: ActivityType[];
            fromDate?: Date;
            toDate?: Date;
        }
    ): Promise<Activity[]> {
        const queryBuilder = this.repository.createQueryBuilder('activity')
            .where('activity.organizationId = :organizationId', { organizationId })
            .andWhere(
                '(activity.creatorId = :userId OR ' +
                'EXISTS (SELECT 1 FROM jsonb_array_elements(activity.participants) AS p WHERE p ->> \'userId\' = :userId))',
                { userId }
            );

        if (filters?.status && filters.status.length > 0) {
            queryBuilder.andWhere('activity.status IN (:...statuses)', { 
                statuses: filters.status 
            });
        }

        if (filters?.activityType && filters.activityType.length > 0) {
            queryBuilder.andWhere('activity.activityType IN (:...types)', { 
                types: filters.activityType 
            });
        }

        if (filters?.fromDate) {
            queryBuilder.andWhere('activity.scheduledStartDate >= :fromDate', { 
                fromDate: filters.fromDate 
            });
        }

        if (filters?.toDate) {
            queryBuilder.andWhere('activity.scheduledEndDate <= :toDate', { 
                toDate: filters.toDate 
            });
        }

        queryBuilder.orderBy('activity.scheduledStartDate', 'ASC');

        return await queryBuilder.getMany();
    }

    // ==================== UPDATE OPERATIONS ====================

    /**
     * Update activity (tenant-scoped)
     */
    async updateActivity(id: string, updates: Partial<Activity>): Promise<Activity> {
        const activity = await this.findById(id);
        if (!activity) {
            throw new Error('Activity not found');
        }

        // Update allowed fields
        const allowedUpdates = [
            'title', 'description', 'visibility', 'scheduledStartDate', 'scheduledEndDate',
            'estimatedDuration', 'location', 'systemLocation', 'maxParticipants',
            'minParticipants', 'roleRequirements', 'resourceRequirements',
            'rewardCredits', 'rewardReputation', 'tags', 'categories', 'metadata'
        ];

        const filteredUpdates: Partial<Activity> = {};
        for (const key of allowedUpdates) {
            if (key in updates) {
                (filteredUpdates as any)[key] = (updates as any)[key];
            }
        }

        Object.assign(activity, filteredUpdates);
        activity.updatedAt = new Date();

        const updatedActivity = await this.repository.save(activity);
        
        logger.info(`Activity updated: ${id}`);
        return updatedActivity;
    }

    /**
     * Update activity status (tenant-scoped)
     */
    async updateStatus(activityId: string, status: ActivityStatus, userId: string): Promise<Activity> {
        const activity = await this.findById(activityId);
        if (!activity) {
            throw new Error('Activity not found');
        }

        // Check if user has permission to update status
        const isCreator = activity.creatorId === userId;
        const isParticipant = activity.participants?.some(p => p.userId === userId);
        
        if (!isCreator && !isParticipant) {
            throw new Error('User not authorized to update activity status');
        }

        activity.status = status;
        activity.updatedAt = new Date();

        const updatedActivity = await this.repository.save(activity);
        
        logger.info(`Activity status updated: ${activityId} to ${status} by ${userId}`);
        return updatedActivity;
    }

    // ==================== DELETE OPERATIONS ====================

    /**
     * Delete activity (tenant-scoped)
     */
    async deleteActivity(id: string, userId: string): Promise<void> {
        const activity = await this.findById(id);
        if (!activity) {
            throw new Error('Activity not found');
        }

        // Only creator can delete
        if (activity.creatorId !== userId) {
            throw new Error('Only activity creator can delete this activity');
        }

        // Can only delete draft or cancelled activities
        if (activity.status !== ActivityStatus.DRAFT && activity.status !== ActivityStatus.CANCELLED) {
            throw new Error('Can only delete draft or cancelled activities');
        }

        await this.repository.remove(activity);
        
        logger.info(`Activity deleted: ${id} by ${userId}`);
    }

    // ==================== STATISTICS ====================

    /**
     * Get activity statistics (tenant-scoped)
     */
    async getStatistics(organizationId?: string): Promise<ActivityStatistics> {
        const whereClause = organizationId ? { organizationId } : {};
        
        const activities = await this.repository.find({
            where: whereClause
        });

        const stats: ActivityStatistics = {
            total: activities.length,
            byType: {} as Record<ActivityType, number>,
            byStatus: {} as Record<ActivityStatus, number>,
            totalParticipants: 0,
            averageParticipants: 0,
            completionRate: 0,
            upcomingCount: 0,
            overdueCount: 0
        };

        // Initialize counters
        for (const type of Object.values(ActivityType)) {
            stats.byType[type] = 0;
        }
        for (const status of Object.values(ActivityStatus)) {
            stats.byStatus[status] = 0;
        }

        const now = new Date();
        let completedCount = 0;

        for (const activity of activities) {
            // Count by type
            stats.byType[activity.activityType]++;
            
            // Count by status
            stats.byStatus[activity.status]++;
            
            // Count participants
            const participantCount = activity.participants?.length || 0;
            stats.totalParticipants += participantCount;
            
            // Count completed
            if (activity.status === ActivityStatus.COMPLETED) {
                completedCount++;
            }
            
            // Count upcoming
            if (activity.scheduledStartDate && activity.scheduledStartDate > now) {
                stats.upcomingCount++;
            }
            
            // Count overdue
            if (activity.scheduledEndDate && 
                activity.scheduledEndDate < now && 
                activity.status === ActivityStatus.ACTIVE) {
                stats.overdueCount++;
            }
        }

        stats.averageParticipants = stats.total > 0 ? 
            Math.round(stats.totalParticipants / stats.total * 100) / 100 : 0;
        
        stats.completionRate = stats.total > 0 ? 
            Math.round(completedCount / stats.total * 100) / 100 : 0;

        return stats;
    }

    // ==================== UTILITY METHODS ====================

    /**
     * Find activity by bounty ID
     */
    async findByBountyId(bountyId: string): Promise<Activity | null> {
        return await this.repository.findOne({
            where: {
                metadata: {
                    bountyId: bountyId
                }
            } as any
        });
    }

    /**
     * Find activity by mission ID
     */
    async findByMissionId(missionId: string): Promise<Activity | null> {
        return await this.repository.findOne({
            where: {
                metadata: {
                    missionId: missionId
                }
            } as any
        });
    }
}