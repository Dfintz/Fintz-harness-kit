/**
 * Flatten all FAQ items across categories for search
 */
function getAllFaqItems() {
    return exports.faqCategories.flatMap(cat => cat.items.map(item => ({
        ...item,
        categoryId: cat.id,
        categoryTitle: cat.title,
    })));
}
/**
 * Search FAQ items by query string (matches question, answer, and keywords)
 */
function searchFaqItems(query) {
    const lowerQuery = query.toLowerCase().trim();
    if (!lowerQuery)
        return [];
    return getAllFaqItems().filter(item => item.question.toLowerCase().includes(lowerQuery) ||
        item.answer.toLowerCase().includes(lowerQuery) ||
        item.keywords.some(kw => kw.toLowerCase().includes(lowerQuery)));
}
