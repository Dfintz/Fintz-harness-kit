# Discord Bot Configuration Example
# Copy this to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# Security Configuration
JWT_SECRET=your-secure-jwt-secret-key-change-this
CORS_ORIGIN=*

# ===================================
# DISCORD BOT SETUP (REQUIRED)
# ===================================

# 1. Get your bot token from Discord Developer Portal
#    https://discord.com/developers/applications
#    Navigate to: Your App > Bot > Token (Click "Reset Token" if needed)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# 2. Get your Application ID from Discord Developer Portal
#    Navigate to: Your App > General Information > Application ID
DISCORD_CLIENT_ID=your-application-id-here

# Discord SSO Configuration (Optional - for OAuth login)
# The backend handles the full OAuth flow (initiate + callback).
# This must point to the backend callback endpoint.
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI_BACKEND=http://localhost:3000/api/v2/auth/discord/callback

# API Configuration for Bot
# URL where your backend API is running
API_BASE_URL=http://localhost:3000/api

# Bot-to-API Internal Authentication
# Shared secret for authenticating bot API calls (must match backend BOT_INTERNAL_SECRET)
# Generate with: openssl rand -base64 32
BOT_INTERNAL_SECRET=your-bot-internal-secret-change-in-production

# Role IPC signing secret used to verify signed role mutation messages from worker.
# Preferred: set BOT_IPC_ROLE_SIGNING_SECRET explicitly and keep it identical on worker and bot.
# Compatibility fallback: if BOT_IPC_ROLE_SIGNING_SECRET is unset, INTERNAL_SERVICE_SECRET is used.
BOT_IPC_ROLE_SIGNING_SECRET=
INTERNAL_SERVICE_SECRET=

# Internal URL for bot-to-API calls (bypasses Front Door in Docker/Azure)
# When running in Docker: http://backend:3000/api
# When running locally alongside backend: http://localhost:3000/api
BOT_API_INTERNAL_URL=http://localhost:3000/api

# ===================================
# DATABASE CONFIGURATION
# ===================================

# Database type: 'postgres' or 'sqlite'
DB_TYPE=sqlite

# PostgreSQL Configuration (when DB_TYPE=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sc_fleet_manager

# SQLite Configuration (when DB_TYPE=sqlite)
DB_PATH=./data/sc_fleet_manager.db

# ===================================
# RSI API CONFIGURATION
# ===================================

RSI_API_URL=https://sentry.wildknightsquadron.com/api
RSI_API_TIMEOUT=10000

# ===================================
# SETUP CHECKLIST
# ===================================

# [ ] Created Discord Application at https://discord.com/developers/applications
# [ ] Added bot to your Discord server
# [ ] Enabled required bot intents (Server Members, Message Content)
# [ ] Copied bot token to DISCORD_BOT_TOKEN
# [ ] Copied application ID to DISCORD_CLIENT_ID
# [ ] Set API_BASE_URL to your backend URL
# [ ] Configured database settings
# [ ] Run: npm install
# [ ] Run: npm start (or npm run start:bot for standalone)
# [ ] Wait for "✅ Discord Bot logged in as..." message
# [ ] Test with /ping command in Discord
