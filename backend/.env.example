# Server Configuration
PORT=3000
NODE_ENV=development
# Frontend URL for OAuth redirects after successful authentication
# For local development: http://localhost:3001
# For production: https://fringecore.space
FRONTEND_URL=http://localhost:3001

# Security Configuration
# Note: In production, these should be stored in Azure Key Vault
# See docs/security/SECRETS_MANAGEMENT.md for migration guide

# SECURITY: Use a secure JWT secret in production (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# SECURITY: Cookie secret for signing cookies (REQUIRED in production, minimum 32 characters)
# Without this, cookies can be tampered with by clients
# Generate with: openssl rand -base64 32
COOKIE_SECRET=your-cookie-secret-change-in-production-min-32-chars

# CORS Configuration
# SECURITY: Set specific CORS origins in production - never use * in production!
# When using wildcard (*), cookie-based authentication will NOT work!
#
# Production example (single domain):
#   CORS_ORIGIN=https://fringecore.space
#
# Production example (multiple domains):
#   CORS_ORIGIN=https://fringecore.space,https://www.fringecore.space
#
# When CORS_ORIGIN is set to a specific domain:
#   - Access-Control-Allow-Credentials is ENABLED (allows cookies/auth headers)
#   - Preflight requests are cached for 24 hours (maxAge: 86400)
#   - Frontend can send authentication cookies
#
# For development only:
CORS_ORIGIN=*

# SECURITY: Required in production for secure token storage (minimum 32 characters)
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=your-token-encryption-key-change-in-production

# SECURITY: Required in production for stable encryption key derivation (64 hex characters)
# Generate with: openssl rand -hex 32 (produces 64 hex characters = 32 bytes)
# WARNING: Changing this value will make existing encrypted tokens unreadable
# This value MUST remain stable across deployments and restarts
TOKEN_ENCRYPTION_SALT=your-token-encryption-salt-change-in-production

# Session binding enforcement (A3)
# true: reject token/session binding mismatches with HTTP 403.
# false: warn-only observe mode.
SESSION_BINDING_ENFORCE=true

# Voice Server Authentication — HMAC-SHA256 token signing for Mumble ICE authenticator
# SECURITY: Must be unique, NOT reused from JWT_SECRET. 4h token TTL.
# Generate with: openssl rand -hex 32
VOICE_AUTH_TOKEN_SECRET=

# Swagger API Documentation
# Controls whether Swagger UI is accessible at /api-docs
# SECURITY: In production, Swagger requires authentication by default
# Set SWAGGER_ENABLED=false to completely disable Swagger UI
SWAGGER_ENABLED=true
# SWAGGER_REQUIRE_AUTH controls authentication requirement for /api-docs
# Default: false in development, true in production
# Set to false in production only if you want public API docs (not recommended)
SWAGGER_REQUIRE_AUTH=false

# Logging Configuration
LOG_LEVEL=info

# Audit Logging Configuration
AUDIT_LOG_MAX_SIZE=10485760        # 10MB per file
AUDIT_LOG_MAX_FILES=30             # Keep 30 rotated files
AUDIT_LOG_RETENTION_DAYS=90        # 90 days retention (informational)

# Discord Bot Configuration
# Complete setup guide: docs/DISCORD_DEVELOPER_PORTAL_SETUP.md
# Quick start: docs/DISCORD_SETUP_QUICKSTART.md
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-oauth-client-id
# Bot application ID (for invite links) — may differ from DISCORD_CLIENT_ID
DISCORD_BOT_CLIENT_ID=your-discord-bot-application-id

# Changelog webhook auto-posting
# Optional: if configured, the bot auto-posts newly added changelog entries as embeds.
# Uses Redis to track last posted version and avoid duplicate posts across restarts.
DISCORD_CHANGELOG_WEBHOOK_URL=
# Optional polling interval in milliseconds (minimum 60000, default 900000 = 15 minutes)
DISCORD_CHANGELOG_POLL_INTERVAL_MS=900000
# Optional startup recheck delay in milliseconds (minimum 5000, default 30000; set 0 to disable)
DISCORD_CHANGELOG_STARTUP_RECHECK_MS=30000
# Optional bootstrap mode. false (default): first run sets baseline without posting history.
# true: first run posts the latest entry immediately.
DISCORD_CHANGELOG_POST_ON_FIRST_RUN=false

# Bot-to-API Internal Authentication
# Shared secret used by the bot container to authenticate internal API calls
# Must match the value set in the bot container environment
# Generate with: openssl rand -base64 32
BOT_INTERNAL_SECRET=your-bot-internal-secret-change-in-production

# Role IPC signing secret used between worker and bot for signed role mutation messages.
# Preferred: set BOT_IPC_ROLE_SIGNING_SECRET explicitly and keep it identical on worker and bot.
# Compatibility fallback: if BOT_IPC_ROLE_SIGNING_SECRET is unset, INTERNAL_SERVICE_SECRET is used.
BOT_IPC_ROLE_SIGNING_SECRET=
INTERNAL_SERVICE_SECRET=

# Discord OAuth Configuration - Backend-Only Flow
# Backend handles the complete OAuth flow including state management and redirects
DISCORD_CLIENT_SECRET=your-discord-client-secret
# Backend redirect URI for OAuth token exchange with Discord API
# Must match one of the redirect URIs configured in Discord Developer Portal
# For local development: http://localhost:3000/api/v2/auth/discord/callback
# For production: https://api.fringecore.space/api/v2/auth/discord/callback
DISCORD_REDIRECT_URI_BACKEND=http://localhost:3000/api/v2/auth/discord/callback

# Discord Guild to Organization Mapping
# OPTIONAL: Maps Discord guild IDs to in-app organization IDs for automatic org context in LFG operations
# When configured, LFG posts created in a mapped Discord guild will be automatically associated with the org
# This enables:
#   - Automatic membership enforcement when formalizing LFG posts to Activities
#   - Cross-guild organization coordination through unified Activity records
#   - Audit trail linking Discord operations to organizational records
# Format: JSON object with guild ID keys and org ID values
# Example: {"123456789": "org-uuid-1", "987654321": "org-uuid-2"}
# If empty or invalid JSON, guild mapping is skipped (no org context)
# Get guild ID: Enable Developer Mode in Discord, right-click guild name, copy ID
# Get org ID: From app database or admin panel Organization records
GUILD_ORG_MAP=

# Google OAuth Configuration - Backend-Only Flow
# OPTIONAL: Enables "Continue with Google" SSO. Leave blank to disable the provider.
# Get these from Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Backend redirect URI for OAuth token exchange with Google API
# Must match one of the Authorized redirect URIs configured in the Google Cloud Console
# For local development: http://localhost:3000/api/v2/auth/google/callback
# For production: https://api.fringecore.space/api/v2/auth/google/callback
GOOGLE_REDIRECT_URI_BACKEND=http://localhost:3000/api/v2/auth/google/callback

# Twitch OAuth Configuration - Backend-Only Flow
# OPTIONAL: Enables "Continue with Twitch" SSO. Leave blank to disable the provider.
# Get these from the Twitch Developer Console -> Applications (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=your-twitch-oauth-client-id
TWITCH_CLIENT_SECRET=your-twitch-oauth-client-secret
# Backend redirect URI for OAuth token exchange with Twitch API
# Must match one of the OAuth Redirect URLs configured in the Twitch Developer Console
# For local development: http://localhost:3000/api/v2/auth/twitch/callback
# For production: https://api.fringecore.space/api/v2/auth/twitch/callback
TWITCH_REDIRECT_URI_BACKEND=http://localhost:3000/api/v2/auth/twitch/callback

# Azure AD SSO Configuration - Platform Admin Authentication
# Get these from Azure Portal -> App registrations
# Separate from Discord OAuth for users
AZURE_AD_TENANT_ID=common
AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
# Admin redirect URI (different from user Discord OAuth)
# For local development: http://localhost:3001/admin/login
# For production: https://fringecore.space/admin/login

# API Configuration for Bot
API_BASE_URL=http://localhost:3000/api

# Database Configuration - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
# SECURITY: Use unique, non-default database username in production
DB_USER=postgres
# SECURITY: Use strong, unique password in production (never use 'postgres' or 'password')
DB_PASSWORD=postgres
DB_NAME=sc_fleet_manager
# Database SSL/TLS Configuration
# SECURITY: Enable SSL in production for secure database connections
# Set to 'true' in production (enabled by default when NODE_ENV=production)
DB_SSL=false
# Set to 'false' only if using self-signed certificates (not recommended in production)
DB_SSL_REJECT_UNAUTHORIZED=true
# Database Migration Configuration
# RUN_MIGRATIONS: When 'true', runs database migrations automatically on startup
# In production (NODE_ENV=production), migrations run automatically by default
# In development, set to 'true' to test migrations instead of using DB_SYNCHRONIZE
RUN_MIGRATIONS=false
# DB_SYNCHRONIZE: When 'true', auto-syncs TypeORM schema with database (useful for development)
# SECURITY: MUST be 'false' in production to prevent accidental data loss
# Use migrations (RUN_MIGRATIONS) for production schema changes
DB_SYNCHRONIZE=true

# Database pool configuration (pg driver)
# Tune these per container role (API, worker, bot) to avoid connection starvation.
DB_POOL_MAX=25
DB_POOL_MIN=5
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000

# CAS Scheduler Guardrails (PR-12)
# Desired org-level parallelism for CAS computation.
# Effective concurrency is automatically capped by DB pool headroom.
CAS_SCHEDULER_CONCURRENCY=8
# Fraction of DB pool CAS is allowed to consume (0.1 - 1.0).
CAS_SCHEDULER_POOL_UTILIZATION=0.4

# Redis Cache Configuration
# Local development: use defaults (localhost:6379, no TLS, no password, key auth)
# Azure Managed Redis: set REDIS_HOST, REDIS_PORT=10000, REDIS_TLS_ENABLED=true
# Azure Cache for Redis (retiring Sept 2028): set REDIS_PORT=6380, REDIS_TLS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false
REDIS_TLS_VERIFY_CERTS=true
# Set to true when using Azure Managed Redis with OSS clustering policy
REDIS_CLUSTER_MODE=false
# Authentication mode: 'key' (access key, default) or 'entra' (Entra ID managed identity)
# When set to 'entra', REDIS_PASSWORD is ignored and a token is acquired via DefaultAzureCredential.
# Requires REDIS_AUTH_OBJECT_ID and AZURE_CLIENT_ID to be set.
REDIS_AUTH_MODE=key
# Object ID (Principal ID) of the managed identity — used as the Redis AUTH username for Entra ID
# Only required when REDIS_AUTH_MODE=entra
# REDIS_AUTH_OBJECT_ID=

# Rate Limiting Configuration
# SECURITY: Protects against brute force, DoS attacks, and API abuse
# Window duration in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100
# Enable Redis-backed distributed rate limiting (default: true)
RATE_LIMIT_REDIS_ENABLED=true
# Redis key prefix for rate limit data (default: ratelimit:)
RATE_LIMIT_REDIS_PREFIX=ratelimit:
# Enable rate limit violation logging (default: true)
RATE_LIMIT_LOGGING_ENABLED=true
# Alert threshold: notify after N violations (default: 5)
RATE_LIMIT_ALERT_THRESHOLD=5
# Whitelist specific user IDs (comma-separated, use sparingly)
RATE_LIMIT_WHITELIST_USERS=
# Whitelist specific IPs (comma-separated, use for health checks, monitoring)
RATE_LIMIT_WHITELIST_IPS=
# Role-based rate limit multipliers (higher = more requests allowed)
RATE_LIMIT_ADMIN_MULTIPLIER=5
RATE_LIMIT_PREMIUM_MULTIPLIER=3
RATE_LIMIT_USER_MULTIPLIER=1
RATE_LIMIT_GUEST_MULTIPLIER=0.5

# RSI API Configuration
RSI_API_URL=https://sentry.wildknightsquadron.com/api
RSI_API_TIMEOUT=10000

# UEX Price Feed Configuration
# API documentation: https://uexcorp.space/api/documentation
# Swagger: https://app.swaggerhub.com/apis-docs/dolejska-daniel/UEX-API/v2.1
UEX_API_URL=https://api.uexcorp.uk/2.0
UEX_API_KEY=
# Optional aliases for the same credential value
UEX_API_TOKEN=
UEX_API_BEARER_TOKEN=
# Optional header when UEX key is version-locked
UEX_CLIENT_VERSION=
UEX_API_TIMEOUT=10000

# RSI Crawler Configuration (for direct web crawling)
ENABLE_RSI_CRAWLER_JOB=false
RSI_CRAWLER_TIMEOUT=30000
RSI_CRAWLER_CACHE_TTL=3600
RSI_CRAWLER_RATE_LIMIT=5
RSI_CRAWLER_RATE_REFILL=1
RSI_CRAWLER_JOB_INTERVAL=360

# Email transport behavior
# Set true when an environment intentionally runs without ACS/SMTP so startup logs at info
# instead of warn. Send attempts still fail closed with a non-success result.
EMAIL_TRANSPORT_OPTIONAL=false

# Azure Storage Configuration
# For local development, use connection string:
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=scfleethbgavvwxxc4f6;AccountKey=YOUR_KEY_HERE;EndpointSuffix=core.windows.net
# For production with Managed Identity, use:
AZURE_STORAGE_ACCOUNT_NAME=scfleethbgavvwxxc4f6
AZURE_STORAGE_CONTAINER=images
# Optional: Storage Account Key for SAS token generation (recommended for GDPR exports)
# Required for generating SAS URLs for direct user downloads
# If not provided, downloads will be proxied through the backend (slower but works with Managed Identity)
# AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key

# Application Insights Configuration (Error Tracking & Monitoring)
# REQUIRED: Application Insights connection string for telemetry and error tracking
# Get from: Azure Portal -> Application Insights -> Overview -> Connection String
# Format: InstrumentationKey=xxx;IngestionEndpoint=https://xxx.in.applicationinsights.azure.com/
APPLICATIONINSIGHTS_CONNECTION_STRING=
# Optional: Legacy instrumentation key (use connection string instead)
# APPINSIGHTS_INSTRUMENTATIONKEY=your-instrumentation-key
# Optional: Sampling percentage to control data volume and costs (1-100)
# Lower values reduce costs but may miss some errors
# Defaults: Production=5%, Development=100%
# APPLICATIONINSIGHTS_SAMPLING_PERCENTAGE=5
# Optional: Application version for tracking deployments
# Automatically set in CI/CD, can override for local testing
# APP_VERSION=1.0.0

# GDPR Export Storage Configuration
# Container for GDPR data exports (separate from images for security)
# Uses same storage account as AZURE_STORAGE_ACCOUNT_NAME
# Container will be created automatically with private access
GDPR_EXPORT_CONTAINER=gdpr-exports
# Legacy: Local file system fallback (deprecated, for development only)
# In production, Azure Blob Storage should be used instead
# EXPORT_DIR=/tmp/gdpr-exports

# Azure Key Vault Configuration (RECOMMENDED for production)
# When configured, secrets are automatically retrieved from Key Vault
# Falls back to environment variables if Key Vault is not available
# See docs/security/SECRETS_MANAGEMENT.md for setup instructions
AZURE_KEY_VAULT_NAME=sc-fleet-keyvault
# AZURE_CLIENT_ID is only needed when not using default Azure credentials
# AZURE_CLIENT_ID=your-managed-identity-client-id

# Encryption Configuration
# IMPORTANT: In production, use a secure 32-byte (64 hex characters) encryption key
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-encryption-key-change-in-production-must-be-64-hex-chars

# Admin Portal Encryption Configuration
# For data obfuscation in admin portal
# Generate AES-256 key: openssl rand -hex 32
# Generate IV: openssl rand -hex 16
ADMIN_ENCRYPTION_KEY=your-admin-encryption-key-32-bytes-64-hex-chars
ADMIN_ENCRYPTION_IV=your-admin-encryption-iv-16-bytes-32-hex-chars

# GDPR Data Retention Configuration
# Time periods in days for automated data cleanup and anonymization
ACCESS_LOG_RETENTION_DAYS=90       # AccountAccessLog deletion (default: 90 days)
USER_ACTIVITY_RETENTION_DAYS=180   # UserActivity anonymization (default: 180 days)
DATA_RETENTION_DAYS=365             # Global data retention policy (default: 365 days)

# Intel Vault Audit Log Rotation Configuration
# Audit logs are rotated daily at 4 AM in production
INTEL_AUDIT_LOG_RETENTION_DAYS=30  # Intel audit log retention (default: 30 days)
INTEL_AUDIT_LOG_ARCHIVE=false      # Enable archiving before deletion (default: false)

# Intel Vault Encryption at Rest Configuration
# Encrypts sensitive Intel content based on classification level
INTEL_ENCRYPTION_ENABLED=true      # Enable encryption (default: true in production)
INTEL_ENCRYPTION_MIN_LEVEL=confidential  # Minimum level to encrypt: public, restricted, confidential, secret, top_secret

# Ship Data Fetcher Configuration
# Google Sheets URLs for ship and vehicle data (must be publicly accessible)
# Use format: https://docs.google.com/spreadsheets/d/{SHEET_ID}/export?format=csv&gid={GID}
# Leave empty to disable automatic ship data updates
SHIP_DATA_SHEET_1=
SHIP_DATA_SHEET_2=

# Email/SMTP Configuration
# Required for password reset, notifications, and GDPR data export emails
# For Gmail: Use App Password (not regular password) - https://support.google.com/accounts/answer/185833
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
# SECURITY: Use environment-specific credentials, never commit actual values
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@fringecore.space

# Azure Communication Services Email (production — preferred over SMTP)
# When set, ACS is used instead of SMTP. Free tier: 100 emails/day.
# Get the connection string from Azure Portal → Communication Services → Keys
ACS_CONNECTION_STRING=
# Sender address configured on your verified domain (e.g., noreply@fringecore.space)
ACS_EMAIL_SENDER_ADDRESS=noreply@fringecore.space

# ========================
# Azure OpenAI Configuration
# ========================
# AI briefing generation is an unreleased feature and is DISABLED by default.
# It only activates when AI_BRIEFING_ENABLED=true AND the Azure OpenAI settings
# below are provided. Leave this unset/false to keep the feature off for release.
AI_BRIEFING_ENABLED=false
# Required for AI briefing generation (Phase 3.1.2 — Wave 3.1)
# Without these, AI generation is disabled (graceful fallback)
# Deploy a gpt-4o-mini model in Azure OpenAI Studio, then fill in:
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_MODEL=gpt-4o-mini

# AI Rate Limiting & Token Limits
# Maximum AI briefing generations per organization per day
AI_BRIEFING_MAX_DAILY_PER_ORG=50
# Maximum completion tokens per AI request
AI_BRIEFING_MAX_TOKENS=2000
