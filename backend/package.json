    "@socket.io/redis-adapter": "^8.3.0",
    "@types/joi": "^17.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "applicationinsights": "^3.15.0",
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.3",
    "bullmq": "^5.78.0",
    "cheerio": "^1.1.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
