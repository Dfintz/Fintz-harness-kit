    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "jest": "30",
    "jest-environment-node": "^30.4.1",
    "openapi-typescript": "^6.7.6",
