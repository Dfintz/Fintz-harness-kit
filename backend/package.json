{
  "name": "star-citizen-dashboard-backend",
  "version": "1.0.0",
  "description": "Backend for Star Citizen Dashboard, managing fleet, user, and organization relations.",
  "main": "src/app.ts",
  "scripts": {
    "start": "ts-node src/app.ts",
    "start:bot": "ts-node src/bot/botApp.ts",
    "build": "tsc",
    "test": "jest",
    "test:pact": "jest --testMatch='**/pact/**/*.pact.test.ts'",
    "test:pact:verify": "npm run test:pact",
    "test:openapi": "jest --testMatch='**/openapi/**/*.test.ts' --forceExit",
    "test:openapi:spec": "jest src/__tests__/openapi/openapi-spec.test.ts --forceExit",
    "test:openapi:coverage": "jest src/__tests__/openapi/openapi-coverage.test.ts --forceExit",
    "test:openapi:endpoints": "jest src/__tests__/openapi/openapi-endpoint-validation.test.ts --forceExit",
    "test:contract": "npm run test:pact && npm run test:openapi",
    "lint": "eslint src/ --max-warnings 5500",
    "lint:fix": "eslint src/ --fix --max-warnings 5500",
    "lint:fix:staged": "eslint --fix --max-warnings 999999",
    "type-check": "npm run build -w @sc-fleet-manager/shared-types && tsc --noEmit",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "update:check": "npm outdated",
    "populate:ships": "ts-node src/scripts/importShips.ts",
    "seed:ships": "ts-node scripts/seed-ships.ts",
    "update:ships": "ts-node scripts/update-ships-from-delta.ts",
    "db:init": "ts-node src/scripts/init-database.ts",
    "db:clean": "ts-node src/scripts/clean-database.ts",
    "seed:admin": "ts-node src/scripts/seed-admin.ts",
    "seed:demo": "ts-node scripts/seed-demo-data.ts",
    "seed:comprehensive": "ts-node scripts/seed-comprehensive.ts",
    "seed:all": "npm run seed:ships && npm run seed:demo && npm run seed:comprehensive",
    "seed:dev": "npm run db:clean && npm run seed:all",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/database.ts",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:run": "npm run typeorm -- migration:run -d src/config/database.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/database.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/config/database.ts",
    "openapi:bundle": "node scripts/bundle-openapi.js",
    "openapi:generate": "openapi-typescript openapi/bundled.yaml -o src/types/generated/api.ts",
    "graphql:generate": "graphql-codegen --config codegen.ts",
    "graphql:watch": "graphql-codegen --config codegen.ts --watch",
    "graphql:generate-manifest": "ts-node scripts/generate-query-manifest.ts",
    "graphql:validate-queries": "ts-node scripts/validate-persisted-queries.ts",
    "graphql:migrate-queries": "ts-node scripts/migrate-queries.ts"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.0.3",
    "@apollo/server": "5.5.0",
    "@as-integrations/express4": "^1.1.2",
    "@azure/communication-email": "^1.1.0",
    "@azure/identity": "^4.13.1",
