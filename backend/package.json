    "json2csv": "^5.0.7",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.10",
    "openai": "^6.42.0",
    "opossum": "^9.0.0",
    "otpauth": "^9.5.0",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.3",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsyringe": "^4.10.0",
    "typeorm": "^0.3.30",
    "undici": ">=7.18.2",
    "uuid": "^11.1.1",
    "winston": "^3.18.3",
    "ws": "^8.20.1",
    "yocto-queue": "^1.2.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/introspection": "^5.0.0",
    "@graphql-codegen/typescript": "^5.0.7",
    "@graphql-codegen/typescript-resolvers": "^5.1.5",
    "@pact-foundation/pact": "^16.0.4",
    "@types/bcrypt": "^6.0.0",
