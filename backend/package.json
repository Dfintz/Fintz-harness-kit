    "@types/multer": "^2.0.0",
    "@types/node": "^25.9.2",
    "@types/node-cache": "^4.1.3",
    "@types/nodemailer": "^7.0.3",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
