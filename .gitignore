# Dependencies
node_modules/

# Harness run journals + generated dashboard (local observability, not source)
.github/harness/runs/*.json
.github/harness/runs/report.html
.github/harness/runs/prompt-packs/

# OpenTelemetry exports (generated from journals; portable telemetry, not source)
.github/harness/otel/

# Parallel-experiment worktrees (Proposal B — ephemeral, never source)
.github/harness/worktrees/

# Research briefs are UNTRUSTED scraped content — never commit them (the README stays tracked)
.github/harness/research/*
!.github/harness/research/README.md

# Knowledge graph cache (regenerated; optional feature)
.cache/
.pnpm-store/
.understand-anything/
.understand-anything-plugin-placeholder/

# Local config overrides
harness.config.local.json

# OS / editor noise
.DS_Store
*.log

# Editor-local settings (not part of the kit)
.vscode/settings.json
