# Frontend Environment Variables
# Copy this file to .env.local for local development
# In production, set these in your build environment or CI/CD pipeline

# ============================================================================
# REQUIRED - API Configuration
# ============================================================================

# Backend API URL
# ⚠️  CRITICAL: This value is embedded at BUILD TIME into the frontend bundle
# You MUST rebuild the frontend after changing this value
#
# For local development: 
#   - Leave empty to use Vite's proxy (configured in vite.config.ts)
#   - Proxy automatically forwards /api and /socket.io to http://localhost:3000
#
# For production/CI/CD: 
#   - Set to your actual backend URL in GitHub Secrets (VITE_API_URL)
#   - Example: https://api.yourdomain.com or https://yourdomain.com/api
#
# If not set in production builds:
#   - Frontend will use relative URLs (/api/...)
#   - Requires frontend and backend on same domain OR reverse proxy
# 
# Examples:
#   Subdomain:        https://api.yourdomain.com
#   Path-based:       https://yourdomain.com/api
#   With port:        https://yourdomain.com:3000
#
# ⚠️  WARNING: If set to an invalid or non-existent domain:
#   - All API calls will fail with "Failed to fetch" or ERR_NAME_NOT_RESOLVED
#   - Error message will show: "Cannot connect to backend server at <URL>"
#
# For detailed configuration guide, see: docs/API_ENDPOINT_CONFIGURATION.md
VITE_API_URL=

# ============================================================================
# Discord OAuth Configuration (Backend-Only Flow)
# ============================================================================

# NOTE: Discord OAuth is now fully handled by the backend.
# Frontend no longer needs Discord Client ID or Redirect URI configuration.
# Users are redirected to /api/v2/auth/discord which handles the entire OAuth flow.
#
# The backend manages:
# - OAuth state generation and CSRF protection
# - Discord API communication
# - Token exchange
# - User session creation
# - Redirect back to frontend with success/error status
#
# No frontend environment variables needed for Discord OAuth!
# The VITE_DISCORD_CLIENT_ID and VITE_DISCORD_REDIRECT_URI variables
# have been removed as they are no longer used.

# ============================================================================
# OPTIONAL - Azure AD OAuth Configuration (for admin portal)
# ============================================================================

# Azure AD Tenant ID
# Get from: Azure Portal -> App registrations -> Overview
# Use 'common' for multi-tenant applications
VITE_AZURE_AD_TENANT_ID=common

# Azure AD Application Client ID
# Get from: Azure Portal -> App registrations -> Overview
VITE_AZURE_AD_CLIENT_ID=your-azure-ad-client-id

# Azure AD OAuth Redirect URI
# This should match the redirect URI configured in your Azure AD application
# For local development: http://localhost:3001/admin/login
# For production: https://fringecore.space/admin/login
VITE_AZURE_AD_REDIRECT_URI=http://localhost:3001/admin/login

# ============================================================================
# OPTIONAL - Discord Bot Invite
# ============================================================================

# Discord bot invite URL for the "Add to Server" button on the landing page
# Generate from Discord Developer Portal -> OAuth2 -> URL Generator
# Select scopes: bot, applications.commands
# Select permissions as needed (e.g., Send Messages, Manage Roles, etc.)
# Example: https://discord.com/oauth2/authorize?client_id=YOUR_BOT_CLIENT_ID&permissions=268435456&scope=bot%20applications.commands
VITE_DISCORD_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_BOT_CLIENT_ID&scope=bot+applications.commands&permissions=1419813317751
# Bot application ID — used to construct invite URL if VITE_DISCORD_BOT_INVITE_URL is not set
# This is the bot's Application ID from Discord Developer Portal (NOT the OAuth client ID)
VITE_DISCORD_BOT_CLIENT_ID=your-discord-bot-application-id

# ============================================================================
# OPTIONAL - WebSocket Configuration
# ============================================================================

# WebSocket URL for real-time features
# For local development: leave empty to use proxy
# For production: set to your WebSocket URL (e.g., wss://api.yourdomain.com)
VITE_WS_URL=

# ============================================================================
# OPTIONAL - Security Configuration
# ============================================================================

# Enable one-time-per-session Guide Mode auto-start for live demos.
# Set to true in demo environments to automatically launch the guided tour.
VITE_ENABLE_LIVE_DEMO_GUIDE=false

# Encryption key seed for secure client-side storage
# Used to derive encryption keys for IndexedDB storage
# Should be consistent across sessions but can be different per environment
VITE_ENCRYPTION_KEY_SEED=your-encryption-key-seed

# ============================================================================
# NOTES
# ============================================================================

# 1. Environment variables must be prefixed with VITE_ to be exposed to the frontend
#
# 2. For local development:
#    - Copy this file to .env.local
#    - Fill in the required values
#    - The .env.local file is gitignored and won't be committed
#
# 3. For production deployment:
#    - Set environment variables in your deployment platform
#    - Variables are embedded at build time
#    - Rebuild the application when changing environment variables
#
# 4. Discord OAuth Setup:
#    - Create an application at https://discord.com/developers/applications
#    - Add redirect URIs in OAuth2 settings matching your environments
#    - Enable the "identify", "email", and "guilds" scopes
#
# 5. Never commit actual credentials to version control
#
# 6. Troubleshooting API Connection Issues:
#    - ERR_NAME_NOT_RESOLVED: The VITE_API_URL domain doesn't exist or can't be resolved
#      Solution: Verify the domain is correct and accessible
#    - Failed to fetch: The backend server is not running or unreachable
#      Solution: Check that the backend is running and network allows connection
#    - CORS errors: The backend CORS configuration doesn't allow your frontend origin
#      Solution: Update CORS_ORIGIN in backend environment variables
