{
  "project": {
    "name": "Business Process Optimization",
    "description": "Process-improvement business cases driven through the harness domain pack."
  },
  "deliverable": {
    "path": ".github/harness/domains/business-optimization/samples/good.md",
    "kind": "Process-improvement business case"
  },
  "commands": {
    "lint": "node scripts/harness/domain-checks/required-sections.mjs .github/harness/domains/business-optimization/samples/good.md --sections \"Current State|Proposed Change|Impact|Risks|Recommendation\"",
    "typeCheck": "node scripts/harness/domain-checks/figure-reconciliation.mjs .github/harness/domains/business-optimization/samples/good.md",
    "build": "node scripts/harness/domain-checks/claim-substantiation.mjs .github/harness/domains/business-optimization/samples/good.md",
    "test": "node scripts/harness/domain-pack.mjs check business-optimization"
  },
  "routing": {
    "defaultMode": "harness-first",
    "nonTrivialStages": ["frame", "diagnose", "draft", "review-breadth", "review-depth", "feedback"]
  },
  "dashboard": { "port": 8099, "intervalSeconds": 60 }
}
