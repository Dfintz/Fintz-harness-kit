{
  "project": {
    "name": "Finance & Investment Research",
    "description": "Investment research deliverables driven through the harness domain pack."
  },
  "deliverable": {
    "path": ".github/harness/domains/finance-research/samples/good.md",
    "kind": "Investment research memo"
  },
  "commands": {
    "lint": "node scripts/harness/domain-checks/required-sections.mjs .github/harness/domains/finance-research/samples/good.md --sections \"Summary|Thesis|Valuation|Risks|Disclosures|Sources\"",
    "typeCheck": "node scripts/harness/domain-checks/figure-reconciliation.mjs .github/harness/domains/finance-research/samples/good.md",
    "build": "node scripts/harness/domain-checks/citation-integrity.mjs .github/harness/domains/finance-research/samples/good.md",
    "test": "node scripts/harness/domain-pack.mjs check finance-research"
  },
  "routing": {
    "defaultMode": "harness-first",
    "nonTrivialStages": ["frame", "thesis", "draft", "review-breadth", "review-depth", "feedback"]
  },
  "dashboard": { "port": 8099, "intervalSeconds": 60 }
}
