{
  "project": {
    "name": "<Domain title>",
    "description": "<deliverables driven through this harness domain pack>"
  },
  "deliverable": {
    "path": ".github/harness/domains/<your-pack>/samples/good.md",
    "kind": "<the artifact this pack produces>"
  },
  "commands": {
    "lint": "node scripts/harness/domain-checks/required-sections.mjs .github/harness/domains/<your-pack>/samples/good.md --sections \"Summary|Body|Sources\"",
    "build": "node scripts/harness/domain-checks/citation-integrity.mjs .github/harness/domains/<your-pack>/samples/good.md",
    "test": "node scripts/harness/domain-pack.mjs check <your-pack>"
  },
  "routing": {
    "defaultMode": "harness-first",
    "nonTrivialStages": ["frame", "plan", "produce", "review-breadth", "review-depth", "feedback"]
  },
  "dashboard": { "port": 8099, "intervalSeconds": 60 }
}
