{
  "project": {
    "name": "Tourism & Hospitality",
    "description": "Tour package and itinerary proposal deliverables driven through the harness domain pack."
  },
  "deliverable": {
    "path": ".github/harness/domains/tourism/samples/good.md",
    "kind": "Tour package / itinerary proposal"
  },
  "commands": {
    "lint": "node scripts/harness/domain-checks/required-sections.mjs .github/harness/domains/tourism/samples/good.md --sections \"Overview|Itinerary|Inclusions|Pricing|Safety & Cancellation\"",
    "typeCheck": "node scripts/harness/domain-checks/figure-reconciliation.mjs .github/harness/domains/tourism/samples/good.md",
    "build": "node scripts/harness/domain-checks/claim-substantiation.mjs .github/harness/domains/tourism/samples/good.md",
    "test": "node scripts/harness/domain-pack.mjs check tourism"
  },
  "routing": {
    "defaultMode": "harness-first",
    "nonTrivialStages": ["frame", "plan", "draft", "review-breadth", "review-depth", "feedback"]
  },
  "dashboard": { "port": 8099, "intervalSeconds": 60 }
}
