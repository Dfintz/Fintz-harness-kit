{
  "project": {
    "name": "IT Services & Delivery",
    "description": "IT-services delivery deliverables driven through the harness domain pack."
  },
  "deliverable": {
    "path": ".github/harness/domains/it-services/samples/good.md",
    "kind": "Statement of work / service design & runbook"
  },
  "commands": {
    "lint": "node scripts/harness/domain-checks/required-sections.mjs .github/harness/domains/it-services/samples/good.md --sections \"Scope|Architecture|SLA|Runbook|Rollback|Risks\"",
    "typeCheck": "node scripts/harness/domain-checks/checklist-coverage.mjs .github/harness/domains/it-services/samples/good.md",
    "build": "node scripts/harness/domain-checks/claim-substantiation.mjs .github/harness/domains/it-services/samples/good.md",
    "test": "node scripts/harness/domain-pack.mjs check it-services"
  },
  "routing": {
    "defaultMode": "harness-first",
    "nonTrivialStages": ["frame", "design", "draft", "review-breadth", "review-depth", "feedback"]
  },
  "dashboard": { "port": 8099, "intervalSeconds": 60 }
}
