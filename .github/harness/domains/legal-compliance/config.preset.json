{
  "project": {
    "name": "Legal & Compliance",
    "description": "Legal and compliance deliverables driven through the harness domain pack."
  },
  "deliverable": {
    "path": ".github/harness/domains/legal-compliance/samples/good.md",
    "kind": "Contract / compliance memo"
  },
  "commands": {
    "lint": "node scripts/harness/domain-checks/required-sections.mjs .github/harness/domains/legal-compliance/samples/good.md --sections \"Parties|Definitions|Obligations|Liability|Governing Law\"",
    "typeCheck": "node scripts/harness/domain-checks/defined-terms.mjs .github/harness/domains/legal-compliance/samples/good.md",
    "build": "node scripts/harness/domain-checks/citation-integrity.mjs .github/harness/domains/legal-compliance/samples/good.md",
    "test": "node scripts/harness/domain-pack.mjs check legal-compliance"
  },
  "routing": {
    "defaultMode": "harness-first",
    "nonTrivialStages": ["frame", "structure", "draft", "review-breadth", "review-depth", "feedback"]
  },
  "dashboard": { "port": 8099, "intervalSeconds": 60 }
}
