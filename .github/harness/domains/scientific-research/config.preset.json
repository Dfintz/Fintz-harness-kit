{
  "project": {
    "name": "Scientific & Academic Research",
    "description": "Scientific research deliverables driven through the harness domain pack."
  },
  "deliverable": {
    "path": ".github/harness/domains/scientific-research/samples/good.md",
    "kind": "Research manuscript / literature review"
  },
  "commands": {
    "lint": "node scripts/harness/domain-checks/required-sections.mjs .github/harness/domains/scientific-research/samples/good.md --sections \"Abstract|Introduction|Methods|Results|Discussion|References\"",
    "typeCheck": "node scripts/harness/domain-checks/citation-integrity.mjs .github/harness/domains/scientific-research/samples/good.md",
    "build": "node scripts/harness/domain-checks/claim-substantiation.mjs .github/harness/domains/scientific-research/samples/good.md",
    "test": "node scripts/harness/domain-pack.mjs check scientific-research"
  },
  "routing": {
    "defaultMode": "harness-first",
    "nonTrivialStages": ["frame", "design", "draft", "review-breadth", "review-depth", "feedback"]
  },
  "dashboard": { "port": 8099, "intervalSeconds": 60 }
}
