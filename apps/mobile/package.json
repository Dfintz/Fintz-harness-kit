{
  "name": "@sc-fleet-manager/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "android": "expo start --android",
    "web": "expo start --web",
    "build": "tsc --noEmit",
    "build:apk": "eas build --platform android --profile preview --non-interactive",
    "build:apk:prod": "eas build --platform android --profile production --non-interactive",
    "test": "jest",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs');['.expo','node_modules'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}));\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/core": "^7.17.4",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "axios": "^1.15.0",
    "expo": "~56.0.9",
    "expo-build-properties": "~56.0.17",
    "expo-constants": "~56.0.17",
    "expo-crypto": "~56.0.0",
    "expo-linking": "~56.0.0",
    "expo-status-bar": "~56.0.0",
    "expo-web-browser": "~56.0.0",
    "react": "19.2.3",
    "react-native": "^0.85.3",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "socket.io-client": "^4.8.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.85.3",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@types/react": "~19.2.17",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.3.0",
    "react-test-renderer": "19.2.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "uuid": "11.1.1",
    "xcode": {
      "uuid": "11.1.1"
    },
    "@expo/config-plugins": {
      "xcode": {
        "uuid": "11.1.1"
      }
    }
  }
}
