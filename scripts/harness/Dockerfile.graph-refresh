FROM node:22-bookworm-slim

# git is required for graph commit hash resolution and optional auto-commit mode.
RUN apt-get update \
  && apt-get install -y --no-install-recommends git ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

CMD ["node", "scripts/harness/graph-refresh-loop.mjs", "--plugin-root", "/opt/understand-plugin"]
