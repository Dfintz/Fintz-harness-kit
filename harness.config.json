{
  "project": {
    "name": "<PROJECT_NAME>",
    "description": "<one-line description of the project the harness runs against>"
  },
  "commands": {
    "lint": "npm run lint",
    "lintFix": "npm run lint:fix",
    "typeCheck": "npm run type-check",
    "build": "npm run build",
    "test": "npm test",
    "testBackend": "npm test",
    "testFrontend": "npm test"
  },
  "models": {
    "implementer": {
      "provider": "anthropic",
      "model": "claude-fable-5",
      "useFor": ["implement", "build-fix", "test-fix", "code edits", "targeted refactors"],
      "note": "Best agentic coder by SWE-bench (95.0% Verified, 80.3% Pro as of 2026-06). Verify availability before pinning — reports of export-control restrictions; fall back to claude-opus-4.8 or a codex model if unavailable."
    },
    "reviewer": {
      "provider": "openai",
      "model": "gpt-5.5",
      "useFor": ["review-breadth", "cross-model review"],
      "note": "Strong, systematic structured-reasoning reviewer; distinct provider from the implementer."
    },
    "arbiter": {
      "provider": "anthropic",
      "model": "claude-opus-4.8",
      "useFor": ["architect", "feedback"],
      "note": "Nuanced judgment for design + adjudication. Feedback fallback when routing.stageModels.feedback is unset (still distinct from the reviewers)."
    }
  },
  "graph": {
    "enabled": false,
    "pluginRoot": "<absolute path to a local Understand-Anything plugin checkout, or leave blank>",
    "path": ".understand-anything/knowledge-graph.json"
  },
  "llm": {
    "provider": "ollama",
    "model": "qwen2.5-coder:14b",
    "embedModel": "nomic-embed-text",
    "ollama": { "host": "http://localhost:11434" },
    "lmstudio": { "host": "http://localhost:1234" }
  },
  "experiments": {
    "exampleMetricCommand": "npm run lint",
    "exampleMetricExtract": "(\\d+) problems",
    "exampleTarget": "src/path/to/a-single-target-file"
  },
  "evolve": {
    "evalAgent": "node scripts/harness/ollama-apply-agent.mjs --model qwen2.5-coder:14b",
    "targetFile": ".github/harness/evolve/candidate-instructions.md",
    "description": "Meta-loop for iterative refinement of harness routing guidance based on experiment scoring"
  },
  "traceGrading": {
    "stallAllowance": 1,
    "minGrade": null,
    "strictMode": true,
    "earlyStop": 2,
    "description": "Deterministic trajectory scoring for convergence loops and workflow metrics",
    "scorer": "scripts/harness/grade-trace.mjs"
  },
  "otel": {
    "serviceName": "harness-kit",
    "endpoint": null,
    "localPath": ".github/harness/otel",
    "writeJson": true,
    "description": "OpenTelemetry trace export for observability dashboard",
    "exporter": "scripts/harness/otel-export.mjs"
  },
  "dashboard": {
    "port": 8099,
    "intervalSeconds": 60
  },
  "routing": {
    "defaultMode": "harness-first",
    "requireDistinctReviewerAndImplementer": true,
    "trivialStartsAt": "implement",
    "stageModels": {
      "understand": "gemini-3.1-pro",
      "architect": "claude-opus-4.8",
      "architect-challenge": "gemini-3.1-pro",
      "implement": "claude-fable-5",
      "review-breadth": "gpt-5.5",
      "review-depth": "gemini-3.1-pro",
      "feedback": "claude-opus-4.8"
    },
    "nonTrivialStages": [
      "understand",
      "architect",
      "architect-challenge",
      "implement",
      "review-breadth",
      "review-depth",
      "feedback"
    ],
    "trivialKeywords": [
      "typo",
      "wording",
      "comment",
      "copy",
      "rename",
      "small doc",
      "format"
    ],
    "nonTrivialKeywords": [
      "api",
      "route",
      "schema",
      "entity",
      "migration",
      "database",
      "auth",
      "security",
      "frontend",
      "backend",
      "shared type",
      "infrastructure",
      "docker",
      "azure",
      "ci",
      "review",
      "architecture",
      "loop"
    ],
    "profiles": {
      "feature": {
        "description": "Full feature delivery through the complete stage machine.",
        "mode": "non-trivial",
        "stages": [
          "understand",
          "architect",
          "architect-challenge",
          "implement",
          "review-breadth",
          "review-depth",
          "feedback"
        ]
      },
      "review": {
        "description": "Independent review path without an implementation handoff.",
        "mode": "review-only",
        "stages": ["understand", "review-breadth", "review-depth", "feedback"]
      }
    }
  },
  "prSize": {
    "baseRef": "origin/main",
    "suggestedLimit": 400,
    "hardLimit": 800,
    "exemptGlobs": [
      "**/*.snap",
      "**/dist/**",
      "**/coverage/**",
      "**/*.min.js",
      "**/package-lock.json",
      "**/pnpm-lock.yaml",
      "**/yarn.lock"
    ]
  }
}
