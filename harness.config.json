{
  "project": {
    "name": "<PROJECT_NAME>",
    "description": "<one-line description of the project the harness runs against>"
  },
  "commands": {
    "lint": "npm run lint",
    "lintFix": "npm run lint:fix",
    "typeCheck": "npm run type-check",
    "build": "npm run build",
    "test": "npm test",
    "testBackend": "npm test",
    "testFrontend": "npm test"
  },
  "models": {
    "implementer": {
      "provider": "github-copilot",
      "model": "gpt-5.3-codex",
      "useFor": [
        "implement",
        "build-fix",
        "test-fix",
        "code edits",
        "targeted refactors"
      ]
    },
    "reviewer": {
      "provider": "anthropic",
      "model": "claude-opus-4.8",
      "useFor": [
        "understand",
        "architect",
        "review-breadth",
        "review-depth",
        "feedback",
        "cross-model review"
      ]
    }
  },
  "graph": {
    "enabled": false,
    "pluginRoot": "<absolute path to a local Understand-Anything plugin checkout, or leave blank>",
    "path": ".understand-anything/knowledge-graph.json"
  },
  "llm": {
    "provider": "ollama",
    "model": "qwen2.5-coder:14b",
    "embedModel": "nomic-embed-text",
    "ollama": { "host": "http://localhost:11434" },
    "lmstudio": { "host": "http://localhost:1234" }
  },
  "experiments": {
    "exampleMetricCommand": "npm run lint",
    "exampleMetricExtract": "(\\d+) problems",
    "exampleTarget": "src/path/to/a-single-target-file"
  },
  "evolve": {
    "evalAgent": "node scripts/harness/ollama-apply-agent.mjs --model qwen2.5-coder:14b",
    "targetFile": ".github/harness/evolve/candidate-instructions.md",
    "description": "Meta-loop for iterative refinement of harness routing guidance based on experiment scoring"
  },
  "traceGrading": {
    "stallAllowance": 1,
    "minGrade": null,
    "strictMode": true,
    "earlyStop": 2,
    "description": "Deterministic trajectory scoring for convergence loops and workflow metrics",
    "scorer": "scripts/harness/grade-trace.mjs"
  },
  "otel": {
    "serviceName": "harness-kit",
    "endpoint": null,
    "localPath": ".github/harness/otel",
    "writeJson": true,
    "description": "OpenTelemetry trace export for observability dashboard",
    "exporter": "scripts/harness/otel-export.mjs"
  },
  "dashboard": {
    "port": 8099,
    "intervalSeconds": 60
  },
  "routing": {
    "defaultMode": "harness-first",
    "requireDistinctReviewerAndImplementer": true,
    "trivialStartsAt": "implement",
    "nonTrivialStages": [
      "understand",
      "architect",
      "implement",
      "review-breadth",
      "review-depth",
      "feedback"
    ],
    "trivialKeywords": [
      "typo",
      "wording",
      "comment",
      "copy",
      "rename",
      "small doc",
      "format"
    ],
    "nonTrivialKeywords": [
      "api",
      "route",
      "schema",
      "entity",
      "migration",
      "database",
      "auth",
      "security",
      "frontend",
      "backend",
      "shared type",
      "infrastructure",
      "docker",
      "azure",
      "ci",
      "review",
      "architecture",
      "loop"
    ],
    "profiles": {
      "feature": {
        "description": "Full feature delivery through the complete stage machine.",
        "mode": "non-trivial",
        "stages": [
          "understand",
          "architect",
          "implement",
          "review-breadth",
          "review-depth",
          "feedback"
        ]
      },
      "review": {
        "description": "Independent review path without an implementation handoff.",
        "mode": "review-only",
        "stages": ["understand", "review-breadth", "review-depth", "feedback"]
      }
    }
  }
}
