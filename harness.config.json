{
  "project": {
    "name": "<PROJECT_NAME>",
    "description": "<one-line description of the project the harness runs against>"
  },
  "commands": {
    "lint": "npm run lint",
    "lintFix": "npm run lint:fix",
    "typeCheck": "npm run type-check",
    "build": "npm run build",
    "test": "npm test",
    "testBackend": "npm test",
    "testFrontend": "npm test"
  },
  "models": {
    "implementer": {
      "provider": "anthropic",
      "model": "claude-opus-4.8",
      "useFor": ["build-fix", "test-fix", "implement (fallback)"],
      "note": "Role FALLBACK + fix-loop coder (available, 88.6% SWE-bench Verified). The implement STAGE is overridden to claude-fable-5 via routing.stageModels (top agentic coder, 95.0%); remove that entry if Fable is unavailable and implement falls back to this role."
    },
    "reviewer": {
      "provider": "google",
      "model": "gemini-3.1-pro",
      "useFor": ["cross-model review label", "review (fallback)"],
      "note": "Role FALLBACK; cheapest of the set. Actual per-stage reviewers come from routing.stageModels (breadth=Opus for code-review strength, depth=Gemini for abstract multi-hop)."
    },
    "arbiter": {
      "provider": "openai",
      "model": "gpt-5.5",
      "useFor": ["feedback"],
      "note": "Feedback model: lowest hallucination of the set (4.2% w/ thinking) for calibrated, non-anchoring adjudication. Used when routing.stageModels.feedback is unset."
    }
  },
  "graph": {
    "enabled": false,
    "pluginRoot": "<absolute path to a local Understand-Anything plugin checkout, or leave blank>",
    "path": ".understand-anything/knowledge-graph.json"
  },
  "llm": {
    "provider": "ollama",
    "model": "qwen2.5-coder:14b",
    "embedModel": "nomic-embed-text",
    "ollama": { "host": "http://localhost:11434" },
    "lmstudio": { "host": "http://localhost:1234" }
  },
  "experiments": {
    "exampleMetricCommand": "npm run lint",
    "exampleMetricExtract": "(\\d+) problems",
    "exampleTarget": "src/path/to/a-single-target-file"
  },
  "evolve": {
    "evalAgent": "node scripts/harness/ollama-apply-agent.mjs --model qwen2.5-coder:14b",
    "targetFile": ".github/harness/evolve/candidate-instructions.md",
    "description": "Meta-loop for iterative refinement of harness routing guidance based on experiment scoring"
  },
  "traceGrading": {
    "stallAllowance": 1,
    "minGrade": null,
    "strictMode": true,
    "earlyStop": 2,
    "description": "Deterministic trajectory scoring for convergence loops and workflow metrics",
    "scorer": "scripts/harness/grade-trace.mjs"
  },
  "otel": {
    "serviceName": "harness-kit",
    "endpoint": null,
    "localPath": ".github/harness/otel",
    "writeJson": true,
    "description": "OpenTelemetry trace export for observability dashboard",
    "exporter": "scripts/harness/otel-export.mjs"
  },
  "dashboard": {
    "port": 8099,
    "intervalSeconds": 60
  },
  "routing": {
    "defaultMode": "harness-first",
    "requireDistinctReviewerAndImplementer": true,
    "trivialStartsAt": "implement",
    "stageModels": {
      "understand": "gemini-3.1-pro",
      "architect": "claude-opus-4.8",
      "architect-challenge": "gemini-3.1-pro",
      "implement": "claude-fable-5",
      "review-breadth": "claude-opus-4.8",
      "review-depth": "gemini-3.1-pro",
      "feedback": "gpt-5.5"
    },
    "nonTrivialStages": [
      "understand",
      "architect",
      "architect-challenge",
      "implement",
      "review-breadth",
      "review-depth",
      "feedback"
    ],
    "trivialKeywords": [
      "typo",
      "wording",
      "comment",
      "copy",
      "rename",
      "small doc",
      "format"
    ],
    "nonTrivialKeywords": [
      "api",
      "route",
      "schema",
      "entity",
      "migration",
      "database",
      "auth",
      "security",
      "frontend",
      "backend",
      "shared type",
      "infrastructure",
      "docker",
      "azure",
      "ci",
      "review",
      "architecture",
      "loop"
    ],
    "profiles": {
      "feature": {
        "description": "Full feature delivery through the complete stage machine.",
        "mode": "non-trivial",
        "stages": [
          "understand",
          "architect",
          "architect-challenge",
          "implement",
          "review-breadth",
          "review-depth",
          "feedback"
        ]
      },
      "review": {
        "description": "Independent review path without an implementation handoff.",
        "mode": "review-only",
        "stages": ["understand", "review-breadth", "review-depth", "feedback"]
      }
    }
  },
  "prSize": {
    "baseRef": "origin/main",
    "suggestedLimit": 400,
    "hardLimit": 800,
    "exemptGlobs": [
      "**/*.snap",
      "**/dist/**",
      "**/coverage/**",
      "**/*.min.js",
      "**/package-lock.json",
      "**/pnpm-lock.yaml",
      "**/yarn.lock"
    ]
  },
  "simplifyDebt": {
    "marker": "simplify-debt:",
    "pathGlobs": ["*.mjs", "*.js", "*.ts", "*.tsx", "*.jsx"],
    "description": "Convention for marking a deliberately minimal/expedient implementation (anti-over-engineering doctrine) with `// simplify-debt: <reason>` so the shortcut stays discoverable. Run `npm run harness:simplify-debt` to list open items; report-only, not a gate."
  }
}
