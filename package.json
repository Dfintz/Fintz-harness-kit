{
  "name": "harness-kit",
  "version": "1.0.0",
  "description": "Project-agnostic AI agent harness: convergence + workflow + autoresearch-style experiment loops, local-LLM agents, memory, knowledge-graph hooks, and a live metrics dashboard.",
  "private": true,
  "type": "module",
  "scripts": {
    "harness:loops": "node scripts/harness/run-loop.mjs --list",
    "harness:loop": "node scripts/harness/run-loop.mjs",
    "harness:record": "node scripts/harness/record-run.mjs",
    "harness:experiment": "node scripts/harness/run-experiment.mjs",
    "harness:experiment:loop": "node scripts/harness/experiment-loop.mjs",
    "harness:experiment:ollama": "node scripts/harness/experiment-loop.mjs --agent \"node scripts/harness/ollama-apply-agent.mjs --model qwen2.5-coder:14b\"",
    "harness:experiment:lmstudio": "node scripts/harness/experiment-loop.mjs --agent \"node scripts/harness/ollama-apply-agent.mjs --provider lmstudio\"",
    "harness:eval": "node scripts/harness/eval/run-eval.mjs",
    "harness:eval:self-test": "node scripts/harness/eval/run-eval.mjs --self-test",
    "harness:evolve": "node scripts/harness/harness-evolve.mjs",
    "harness:evolve:check": "node scripts/harness/harness-evolve.mjs --check",
    "harness:research": "node scripts/harness/research-ingest.mjs",
    "harness:report": "node scripts/harness/harness-report.mjs",
    "harness:dashboard": "node scripts/harness/report-server.mjs",
    "harness:llm:agent": "node scripts/harness/ollama-agent.mjs",
    "harness:ollama:agent": "node scripts/harness/ollama-agent.mjs",
    "harness:graph:refresh:loop": "node scripts/harness/graph-refresh-loop.mjs",
    "harness:mcp:server": "node scripts/harness/mcp-server.mjs",
    "dashboard:up": "docker compose -f docker-compose.harness.yml --profile dashboard up -d --build harness-dashboard",
    "dashboard:down": "docker compose -f docker-compose.harness.yml --profile dashboard stop harness-dashboard",
    "dashboard:logs": "docker compose -f docker-compose.harness.yml --profile dashboard logs -f harness-dashboard"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "license": "MIT"
}
