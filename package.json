{
  "name": "sc-fleet-manager",
  "version": "1.0.0",
  "description": "**Enterprise-Grade Fleet Management Platform for Star Citizen Organizations**",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "backend",
    "frontend",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "npm exec -- playwright test",
    "test:e2e:ui": "npm exec -- playwright test --ui",
    "test:e2e:debug": "npm exec -- playwright test --debug",
    "test:e2e:report": "npm exec -- playwright show-report",
    "test:e2e:update-snapshots": "npm exec -- playwright test --update-snapshots",
    "playwright:install": "npx playwright install --with-deps chromium firefox",
    "license:check": "license-checker --production --failOn 'GPL-3.0-only;GPL-3.0-or-later;AGPL-3.0-only;AGPL-3.0-or-later;SSPL-1.0;EUPL-1.1;EUPL-1.2' --excludePrivatePackages",
    "license:report": "license-checker --production --csv --out licenses.csv --excludePrivatePackages",
    "prepare": "husky || true",
    "postinstall": "node scripts/security/enforceUuidSupplyChain.cjs",
    "security:enforce-uuid": "node scripts/security/enforceUuidSupplyChain.cjs",
    "qa:check": "node scripts/qa-tool.js",
    "qa:quick": "node scripts/qa-tool.js --quick",
    "qa:api": "node scripts/qa-tool.js --api",
    "qa:db": "node scripts/qa-tool.js --db",
    "qa:security": "node scripts/qa-tool.js --security",
    "qa:smoke": "node scripts/smoke-tests.js",
    "qa:health": "node scripts/health-monitor.js",
    "qa:health:watch": "node scripts/health-monitor.js --watch",
    "qa:all": "npm run qa:check && npm run qa:smoke && npm run qa:health"
  },
  "keywords": [
    "star-citizen",
    "fleet-manager",
    "monorepo"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.1",
    "husky": "^9.1.7",
    "license-checker": "25.0.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.9.14"
  },
  "lint-staged": {
    "backend/**/*.{ts,tsx}": [
      "npm run lint:fix:staged --workspace=backend --",
      "prettier --write"
    ],
    "frontend/**/*.{ts,tsx}": [
      "npm run lint:fix:staged --workspace=frontend --",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@apidevtools/json-schema-ref-parser": "15.3.5",
    "react-is": "^16.13.1",
    "@apollo/server": "5.5.0",
    "uuid": "11.1.1",
    "lodash": ">=4.18.1",
    "lodash-es": ">=4.18.1",
    "eslint": {
      "ajv": "6.14.0"
    },
    "@eslint/eslintrc": {
      "ajv": "6.14.0"
    },
    "fast-xml-parser": ">=5.5.6",
    "shell-quote": "1.8.4",
    "discord.js": {
      "undici": "6.24.1"
    },
    "openapi-typescript": {
      "undici": "6.24.1"
    },
    "sqlite3": "6.0.1",
    "socket.io-parser": ">=4.2.6",
    "flatted": ">=3.4.0",
    "immutable": ">=3.8.3",
    "underscore": ">=1.13.8",
    "@isaacs/brace-expansion": "5.0.1",
    "swagger-jsdoc": {
      "glob": "^10.4.5"
    },
    "react-server-dom-webpack": "0.0.0-experimental-2b036d3f1-20241024",
    "qs": ">=6.14.2",
    "jest-expo": {
      "jest-environment-jsdom": "^30.0.0"
    },
    "@opentelemetry/sdk-node": ">=0.218.0",
    "@opentelemetry/otlp-transformer": ">=0.218.0",
    "protobufjs": "8.4.2",
    "@opentelemetry/otlp-transformer@0.217.0": {
      "protobufjs": "8.4.2"
    },
    "@grpc/proto-loader": {
      "protobufjs": "8.4.2"
    },
    "@expo/config-plugins": {
      "xcode": {
        "uuid": "11.1.1"
      }
    },
    "xcode": {
      "uuid": "11.1.1"
    },
    "xcode@3.0.1": {
      "uuid": "11.1.1"
    },
    "@azure/functions-old": {
      "uuid": "11.1.1"
    },
    "@azure/functions": {
      "uuid": "11.1.1"
    },
    "@storybook/addon-actions": {
      "uuid": "11.1.1"
    },
    "ws": ">=8.20.1",
    "engine.io": ">=6.6.8",
    "engine.io-client": ">=6.6.5",
    "picomatch": "4.0.4",
    "postcss": ">=8.5.10",
    "storybook": "^8.6.15",
    "serialize-javascript": ">=7.0.5",
    "tmp": "0.2.6",
    "@rollup/plugin-terser": {
      "serialize-javascript": ">=7.0.5"
    },
    "workbox-build": {
      "@rollup/plugin-terser": {
        "serialize-javascript": ">=7.0.5"
      }
    }
  }
}
