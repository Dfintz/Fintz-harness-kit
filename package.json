{
  "name": "harness-kit",
  "version": "1.0.0",
  "description": "Project-agnostic AI agent harness: convergence + workflow + autoresearch-style experiment loops, local-LLM agents, memory, knowledge-graph hooks, and a live metrics dashboard.",
  "private": true,
  "type": "module",
  "scripts": {
    "harness:selftest": "node scripts/harness/selftest-all.mjs",
    "harness:doctor": "node scripts/harness/doctor.mjs",
    "harness:doctor:self-test": "node scripts/harness/doctor.mjs --self-test",
    "harness:mcp:config": "node scripts/harness/doctor.mjs --mcp",
    "harness:loops": "node scripts/harness/run-loop.mjs --list",
    "harness:route": "node scripts/harness/prompt-router.mjs route",
    "harness:route:banner": "node scripts/harness/prompt-router.mjs banner",
    "harness:wizard": "node scripts/harness/config-wizard.mjs",
    "harness:wizard:self-test": "node scripts/harness/config-wizard.mjs --self-test",
    "harness:handoff:feature": "node scripts/harness/prompt-router.mjs handoff --profile feature",
    "harness:handoff:review": "node scripts/harness/prompt-router.mjs handoff --profile review",
    "harness:feature": "node scripts/harness/prompt-router.mjs handoff --profile feature",
    "harness:prompt-pack": "node scripts/harness/prompt-router.mjs prompt-pack",
    "harness:loop": "node scripts/harness/run-loop.mjs",
    "harness:record": "node scripts/harness/record-run.mjs",
    "harness:migrate:approvals": "node scripts/harness/migrate-approval-markers.mjs",
    "harness:council:review": "node scripts/harness/council-review.mjs",
    "harness:workspace-memory": "node scripts/harness/workspace-memory.mjs",
    "harness:command-validation:self-test": "node scripts/harness/command-validation.mjs --self-test",
    "harness:experiment": "node scripts/harness/run-experiment.mjs",
    "harness:experiment:loop": "node scripts/harness/experiment-loop.mjs",
    "harness:experiment:ollama": "node scripts/harness/experiment-loop.mjs --agent \"node scripts/harness/ollama-apply-agent.mjs --model qwen2.5-coder:14b\"",
    "harness:experiment:lmstudio": "node scripts/harness/experiment-loop.mjs --agent \"node scripts/harness/ollama-apply-agent.mjs --provider lmstudio\"",
    "harness:eval": "node scripts/harness/eval/run-eval.mjs",
    "harness:eval:self-test": "node scripts/harness/eval/run-eval.mjs --self-test",
    "harness:domains": "node scripts/harness/domain-pack.mjs --list",
    "harness:domain": "node scripts/harness/domain-pack.mjs",
    "harness:domain:check": "node scripts/harness/domain-pack.mjs check",
    "harness:domain:self-test": "node scripts/harness/domain-pack.mjs --self-test",
    "harness:evolve": "node scripts/harness/harness-evolve.mjs",
    "harness:evolve:check": "node scripts/harness/evolve-guard.mjs --check",
    "harness:evolve:verify": "node scripts/harness/evolve-guard.mjs --verify-target",
    "harness:evolve:self-test": "node scripts/harness/evolve-guard.mjs --self-test",
    "harness:evolve:dry-run": "node scripts/harness/harness-evolve.mjs --dry-run",
    "harness:evolve:test": "node scripts/harness/harness-evolve.mjs --self-test",
    "harness:research": "node scripts/harness/research-ingest.mjs",
    "harness:plan-review": "node scripts/harness/plan-review.mjs",
    "harness:review": "node scripts/harness/plan-review.mjs",
    "harness:plan-review:self-test": "node scripts/harness/plan-review.mjs --self-test",
    "harness:skill:curate": "node scripts/harness/skill-curate.mjs",
    "harness:skill:curate:self-test": "node scripts/harness/skill-curate.mjs --self-test",
    "harness:handoff:check": "node scripts/harness/handoff-check.mjs",
    "harness:handoff:check:self-test": "node scripts/harness/handoff-check.mjs --self-test",
    "harness:pr-size": "node scripts/harness/pr-size.mjs",
    "harness:pr-size:enforce": "node scripts/harness/pr-size.mjs --enforce",
    "harness:git-guard": "node scripts/harness/git-guard.mjs",
    "harness:git-guard:self-test": "node scripts/harness/git-guard.mjs --self-test",
    "harness:grade": "node scripts/harness/grade-trace.mjs",
    "harness:grade:self-test": "node scripts/harness/grade-trace.mjs --self-test",
    "harness:otel": "node scripts/harness/otel-export.mjs",
    "harness:otel:self-test": "node scripts/harness/otel-export.mjs --self-test",
    "harness:report": "node scripts/harness/harness-report.mjs",
    "harness:dashboard": "node scripts/harness/report-server.mjs",
    "harness:llm:agent": "node scripts/harness/ollama-agent.mjs",
    "harness:ollama:agent": "node scripts/harness/ollama-agent.mjs",
    "harness:graph:refresh:loop": "node scripts/harness/graph-refresh-loop.mjs",
    "harness:mcp:server": "node scripts/harness/mcp-server.mjs",
    "harness:mcp:status": "node scripts/harness/harness-mcp-tasks.mjs status",
    "harness:mcp:find": "node scripts/harness/harness-mcp-tasks.mjs find",
    "harness:mcp:impact": "node scripts/harness/harness-mcp-tasks.mjs impact",
    "harness:simplify-debt": "node scripts/harness/simplify-debt.mjs",
    "harness:simplify-debt:self-test": "node scripts/harness/simplify-debt.mjs --self-test",
    "harness:start": "node scripts/harness/harness-start.mjs",
    "harness:help": "node scripts/harness/harness-help.mjs",
    "harness:help:self-test": "node scripts/harness/harness-help.mjs --self-test",
    "dashboard:up": "docker compose -f docker-compose.harness.yml --profile dashboard up -d --build harness-dashboard",
    "dashboard:down": "docker compose -f docker-compose.harness.yml --profile dashboard stop harness-dashboard",
    "dashboard:logs": "docker compose -f docker-compose.harness.yml --profile dashboard logs -f harness-dashboard"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "license": "MIT"
}
